# 复制此文件为 .env，按需填写
# cp .env.example .env
#
# LLM 多组配置规则：
#   LLM_NAMES         逗号分隔的配置名（自定义，代码里 llm_config 引用同名）
#   LLM_<NAME>_KEY    对应配置的 API Key
#   LLM_<NAME>_URL    对应配置的 API Base URL（OpenAI 兼容协议）
#   LLM_<NAME>_MODEL  使用的模型名
#   LLM_<NAME>_MAX_TOKENS  最大 token 数（可选，默认 150）

LLM_NAMES=qwen,gpt

# 配置名: qwen（通义千问 / DashScope）
LLM_QWEN_KEY=sk-your-qwen-api-key
LLM_QWEN_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_QWEN_MODEL=qwen-plus
LLM_QWEN_MAX_TOKENS=150

# 配置名: gpt（OpenAI 或其他兼容接口）
LLM_GPT_KEY=sk-your-openai-api-key
LLM_GPT_URL=https://api.openai.com/v1
LLM_GPT_MODEL=gpt-4o-mini
LLM_GPT_MAX_TOKENS=150

# 再加一组示例（复制上面几行，改名即可）
# LLM_NAMES=qwen,gpt,zhipu
# LLM_ZHIPU_KEY=...
# LLM_ZHIPU_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_ZHIPU_MODEL=glm-4-flash
